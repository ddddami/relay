:80 {
  @deployment host *.localhost

  handle @deployment {
    rewrite * /__relay/deploy{uri}
    reverse_proxy api:3000 {
      header_up Host {host}
    }
  }

  handle_path /api/* {
    reverse_proxy api:3000
  }

  handle /apps/* {
    reverse_proxy api:3000
  }

  handle {
    reverse_proxy web:5173
  }
}
